# Copy this file to `.env` and adjust values for your local setup.
# NEVER commit the real .env (it is git-ignored).

# API server port
PORT=4000

# Node environment: development | test | production
NODE_ENV=development

# PostgreSQL connection string.
# Matches the local Docker Compose service (see docker-compose.yml at repo root).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://ticket:ticket@localhost:5432/tickets?schema=public"
